# ──────────────────────────────────────────────────────────────
# KOL Outreach Agent — 环境变量示例
# 复制为 .env 并填入真实值后启动服务
# ──────────────────────────────────────────────────────────────

# ── 阿里企业邮箱（IMAP 收件 + SMTP 发件） ──────────────────────
EMAIL_ADDRESS=your@company.com
EMAIL_PASSWORD=your_email_password
SENDER_DISPLAY_NAME=Sarah from YourBrand   # 发件人显示名，显示在收件人 From 栏

IMAP_HOST=imap.qiye.aliyun.com
IMAP_PORT=993
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465

# ── 大语言模型 ──────────────────────────────────────────────────
# 兼容所有 OpenAI Chat Completions 格式服务商，换供应商只需改以下三行
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 通义千问
# LLM_BASE_URL=https://api.openai.com/v1                         # OpenAI GPT
# LLM_BASE_URL=https://api.deepseek.com/v1                       # DeepSeek
# LLM_BASE_URL=http://localhost:11434/v1                         # 本地 Ollama
LLM_MODEL=qwen-plus
LLM_TIMEOUT=60

# ── 品牌信息 ────────────────────────────────────────────────────
BRAND_NAME=Your Brand Store
BRAND_SIGNATURE=Sarah | Your Brand Partnership Team

# ── 数据库 ──────────────────────────────────────────────────────
DB_FILE=kol_agent.db

# ── 多轮会话记忆 ────────────────────────────────────────────────
# MAX_THREAD_MESSAGES: 每个线程最多送给 LLM 的历史条数（含 KOL + 我方）
MAX_THREAD_MESSAGES=10
# BODY_EXCERPT_LENGTH: 每条邮件正文存入 DB 及送给 LLM 前的截断字符数
BODY_EXCERPT_LENGTH=600

# ── 产品库 ──────────────────────────────────────────────────────
# 指向本地 JSON 产品文件路径（相对项目根目录）
# 修改为真实产品后重启服务即可生效，无需改代码
PRODUCTS_PATH=data/products.json

# ── 服务器 ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
POLL_INTERVAL=120          # 轮询间隔（秒），建议 60-300
MAX_EMAILS_PER_CYCLE=20    # 每轮最多处理的未读邮件数
